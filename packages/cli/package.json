  "version": "0.1.0",
  "description": "BrainShield CLI — AI-powered security analysis for your codebase",
  "type": "module",
  "bin": {
    "brain": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
