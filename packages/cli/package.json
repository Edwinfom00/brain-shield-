{
  "name": "brainsield",
  "version": "0.1.0",
  "description": "AI-powered security analysis CLI for JavaScript/TypeScript codebases",
  "type": "module",
  "bin": {
    "brain": "./dist/index.js",
    "brainsield": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@edwinfom/ai-guard": "^0.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "fast-glob": "^3.3.2",
    "figlet": "^1.11.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.7",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "security",
    "cli",
    "ai",
    "claude",
    "vulnerability",
    "scanner",
    "typescript",
    "nextjs",
    "vite",
    "codebase"
  ],
  "author": "Edwin Fom <edwinfom@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Edwinfom00/brain-shield"
  },
  "homepage": "https://brainsield.dev"
}
