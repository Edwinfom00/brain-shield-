  "knowledgeChunks": [
    {
      "path": "packages\\web\\next.config.ts",
      "hash": "43eff9443183697c",
      "summary": "Standard Next.js configuration file for the 'web' package in a monorepo. It exports a minimal NextConfig object with only React Strict Mode enabled, using TypeScript for type safety.",
      "topics": [
        "config"
      ]
    },
    {
      "path": "packages\\cli\\src\\index.ts",
      "hash": "1c7f1a2c29edbf7a",
      "summary": "Entry point for the 'brain' CLI tool (BrainShield), which uses Commander.js to define and register subcommands (brain, chat, fix, report, config, init) for AI-powered security analysis. It conditionally prints a banner unless machine-readable output is expected (--json or --version flags), and defaults to running the 'brain' scan command when invoked without a subcommand.",
      "topics": [
        "cli",
        "routing",
        "ui",
        "config"
      ]
    },
    {
      "path": "packages\\web\\src\\middleware.ts",
      "hash": "bebedb6d7d6e319e",
      "summary": "This file implements Next.js middleware using Clerk authentication to protect routes matching the `/dashboard` path pattern. It uses Clerk's `createRouteMatcher` to define protected routes and calls `auth.protect()` to enforce authentication on matched requests. The middleware matcher config ensures it runs on all routes except static assets and Next.js internals.",
      "topics": [
        "auth",
        "middleware",
        "routing",
        "config"
      ]
    },
    {
      "path": "packages\\cli\\src\\commands\\config.ts",
      "hash": "e4d64da2e979c57a",
      "summary": "Defines a Commander.js CLI subcommand `config` for managing BrainShield configuration settings, supporting operations to set an Anthropic API key, set a Claude model, and display the current configuration (API key, model, max cost, config path) with styled terminal output using chalk. It persists settings via an imported config store and provides guidance when no API key is configured.",
      "topics": [
        "config",
        "cli",
        "ui",
        "secrets"
      ]
    },
    {
      "path": "packages\\cli\\src\\core\\config.ts",
      "hash": "cc00a5978fa46381",
      "summary": "Defines a persistent configuration store for the BrainShield CLI using the `conf` library, with typed settings for Anthropic API key, model selection (defaulting to claude-opus-4-6), and scan cost/token limits. Provides a `getApiKey()` helper that resolves the Anthropic API key from the environment variable first, falling back to the stored configuration value.",
