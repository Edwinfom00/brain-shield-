{
  "name": "brainsield-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "BrainShield — AI-powered CLI security tool monorepo",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:cli": "pnpm --filter @brainsield/cli dev",
    "dev:web": "pnpm --filter @brainsield/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "workspaces": [
    "packages/*"
  ]
}
